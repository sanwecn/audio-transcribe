# TeleSpeechASR API 配置
# 方式一：SiliconFlow 免费 API（推荐，注册 https://siliconflow.cn 即可）
# TELE_ASR_API=https://api.siliconflow.cn/v1/audio/transcriptions
# TELE_ASR_KEY=sk-xxx

# 方式二：本地部署（使用 vLLM）
# TELE_ASR_API=http://localhost:8000/v1/audio/transcriptions
# TELE_ASR_KEY=local

# API 限速间隔（秒）
TELE_ASR_RATE_LIMIT=2

# 输入/输出路径（可选，有默认值）
# TRANSCRIBE_INPUT_DIR=./input
# TRANSCRIBE_OUTPUT_DIR=./output
